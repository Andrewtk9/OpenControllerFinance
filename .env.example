# Banco de dados local (SQLite)
DATABASE_URL="file:./dev.db"

# Privacidade: desliga a telemetria anônima do Next.js
NEXT_TELEMETRY_DISABLED=1

# Senha de acesso — OBRIGATÓRIA para usar na rede/celular (npm run start:lan)
AUTH_PASSWORD=""

# Credenciais da Pluggy (https://dashboard.pluggy.ai -> sua aplicação)
PLUGGY_CLIENT_ID=""
PLUGGY_CLIENT_SECRET=""

# IDs dos items (conexões bancárias) criados via meu.pluggy.ai, separados por vírgula
# Ex: "item-uuid-nubank,item-uuid-inter,item-uuid-bb,item-uuid-itau,item-uuid-mercadopago"
PLUGGY_ITEM_IDS=""

# Notificações via Telegram (opcional — crie um bot com @BotFather)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_CHAT_ID=""
